{
  "name": "mancolor",
  "version": "1.0.12",
  "private": true,
  "description": "ManColor - Mancala-style board game",
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host 0.0.0.0 --port 3000 --strictPort",
    "room:server": "node server/roomServer.js",
    "room:server:debug-kutakuta": "node -e \"process.env.DEBUG_NEAR_KUTAKUTA='1'; require('./server/roomServer.js')\"",
    "room:server:lan": "node server/roomServer.js",
    "selfplay": "npx esbuild tools/selfplay_evolve.js --bundle --platform=node --outfile=dist-sim/selfplay_evolve.cjs --format=cjs && node dist-sim/selfplay_evolve.cjs",
    "bot": "node bot/botClient.mjs",
    "bot:2": "cross-env BOT_COUNT=2 node bot/botClient.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "preview:lan": "vite preview --host 0.0.0.0 --port 3000 --strictPort",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "release:bundle": "npm run build && npx cap sync && cd android && gradlew.bat bundleRelease",
    "release:apk": "npm run build && npx cap sync && cd android && gradlew.bat assembleRelease"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^7.0.0",
    "firebase": "^11.2.0",
    "phaser": "^3.87.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/cli": "^7.2.0",
    "@capacitor/core": "^7.2.0",
    "cross-env": "^10.1.0",
    "terser": "^5.46.1",
    "vite": "^6.2.6"
  }
}
