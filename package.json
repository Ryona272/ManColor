{
  "name": "mancolor",
  "version": "0.1.0",
  "private": true,
  "description": "ManColor - Mancala-style board game",
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host 0.0.0.0 --port 3000 --strictPort",
    "room:server": "node server/roomServer.js",
    "room:server:debug-kutakuta": "node -e \"process.env.DEBUG_NEAR_KUTAKUTA='1'; require('./server/roomServer.js')\"",
    "room:server:lan": "node server/roomServer.js",
    "build": "vite build",
    "preview": "vite preview",
    "preview:lan": "vite preview --host 0.0.0.0 --port 3000 --strictPort",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android"
  },
  "dependencies": {
    "phaser": "^3.87.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/cli": "^7.2.0",
    "@capacitor/core": "^7.2.0",
    "terser": "^5.46.1",
    "vite": "^6.2.6"
  }
}
